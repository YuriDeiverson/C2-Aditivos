# Copie para .env.local e preencha com os valores do projeto Supabase.
# https://supabase.com/dashboard/project/_/settings/api
#
# O prefixo NEXT_PUBLIC_ é obrigatório para o browser (login, navbar, carrinho).
# Sem isto, o ícone de conta ainda abre /login, mas a sessão Supabase não funciona.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp (somente dígitos, com DDI. Ex: 55 + DDD + número)
NEXT_PUBLIC_WHATSAPP_NUMBER=5582987329774
